<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DataDuck.ViewModels"
             xmlns:m="using:DataDuck.Models"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="400"
             x:Class="DataDuck.Views.ChartView"
             x:DataType="vm:ChartViewModel">

  <Design.DataContext>
    <vm:ChartViewModel/>
  </Design.DataContext>

  <Grid>

    <!-- Empty state -->
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                Spacing="10"
                IsVisible="{Binding IsEmpty}">
      <TextBlock Text="📊" FontSize="42" Opacity="0.3" HorizontalAlignment="Center"/>
      <TextBlock Text="No chart for this query shape"
                 Foreground="{StaticResource DdTextMutedBrush}"
                 HorizontalAlignment="Center" FontSize="13"/>
      <TextBlock Text="Try: SELECT category, SUM(value) FROM table GROUP BY category"
                 Foreground="{StaticResource DdTextMutedBrush}"
                 Opacity="0.6"
                 FontFamily="Consolas, Menlo, monospace"
                 FontSize="11" HorizontalAlignment="Center"
                 TextWrapping="Wrap" MaxWidth="400"/>
    </StackPanel>

    <!-- Big number tile -->
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                Spacing="6"
                IsVisible="{Binding IsBigNumber}">
      <TextBlock Text="{Binding BigNumberLabel}"
                 FontSize="11" FontWeight="Bold" LetterSpacing="2"
                 Foreground="{StaticResource DdTextMutedBrush}"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="{Binding BigNumberValue}"
                 FontSize="64" FontWeight="Bold"
                 Foreground="{StaticResource DdTextPrimaryBrush}"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Horizontal bar chart -->
    <Grid IsVisible="{Binding IsBarChart}" Margin="20" RowDefinitions="Auto,*">
      <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,12">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="{Binding ValueColumn}"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource DdTextPrimaryBrush}"/>
          <TextBlock Text="by"
                     FontSize="13"
                     Foreground="{StaticResource DdTextMutedBrush}"/>
          <TextBlock Text="{Binding CategoryColumn}"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource DdTextPrimaryBrush}"/>
        </StackPanel>
        <TextBlock Text="auto-detected from query result"
                   FontSize="10"
                   Foreground="{StaticResource DdTextMutedBrush}"
                   Opacity="0.7"/>
      </StackPanel>

      <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding BarPoints}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="m:BarPoint">
              <Grid ColumnDefinitions="140,*,90" Height="30" Margin="0,2">
                <TextBlock Text="{Binding Label}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource DdTextPrimaryBrush}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
                <ProgressBar Grid.Column="1"
                             Margin="6,0"
                             Value="{Binding Value}"
                             Maximum="{Binding Max}"
                             Foreground="{StaticResource DdAccentBrush}"
                             Background="{StaticResource DdBgHoverBrush}"
                             MinWidth="60"
                             Height="22"
                             VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding Display}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource DdTextPrimaryBrush}"
                           FontFamily="Consolas, Menlo, monospace"
                           FontSize="12"/>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>

    <!-- Line chart -->
    <Grid IsVisible="{Binding IsLineChart}" Margin="20" RowDefinitions="Auto,*">
      <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,12">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="{Binding ValueColumn}"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource DdTextPrimaryBrush}"/>
          <TextBlock Text="over"
                     FontSize="13"
                     Foreground="{StaticResource DdTextMutedBrush}"/>
          <TextBlock Text="{Binding CategoryColumn}"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource DdTextPrimaryBrush}"/>
        </StackPanel>
        <TextBlock Text="auto-detected from query result"
                   FontSize="10"
                   Foreground="{StaticResource DdTextMutedBrush}"
                   Opacity="0.7"/>
      </StackPanel>

      <Grid Grid.Row="1" ColumnDefinitions="48,*" RowDefinitions="*,20">
        <!-- Y axis labels -->
        <Grid Grid.Column="0" Grid.Row="0" Margin="0,0,4,0">
          <TextBlock Text="{Binding LineYAxisMax}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     FontSize="10" FontFamily="Consolas, Menlo, monospace"
                     Foreground="{StaticResource DdTextMutedBrush}"/>
          <TextBlock Text="{Binding LineYAxisMin}"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     FontSize="10" FontFamily="Consolas, Menlo, monospace"
                     Foreground="{StaticResource DdTextMutedBrush}"/>
        </Grid>

        <!-- Plot area -->
        <Border Grid.Column="1" Grid.Row="0"
                BorderBrush="{StaticResource DdBorderBrush}"
                BorderThickness="0,0,0,1">
          <Canvas Name="LineCanvas"
                  Background="Transparent"
                  ClipToBounds="True"/>
        </Border>

        <!-- X axis labels -->
        <Grid Grid.Column="1" Grid.Row="1" Margin="0,4,0,0">
          <TextBlock Text="{Binding LineXAxisMin}"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     FontSize="10" FontFamily="Consolas, Menlo, monospace"
                     Foreground="{StaticResource DdTextMutedBrush}"/>
          <TextBlock Text="{Binding LineXAxisMax}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     FontSize="10" FontFamily="Consolas, Menlo, monospace"
                     Foreground="{StaticResource DdTextMutedBrush}"/>
        </Grid>
      </Grid>
    </Grid>

    <!-- Pie chart -->
    <Grid IsVisible="{Binding IsPieChart}" Margin="20" RowDefinitions="Auto,*">
      <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,12">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="{Binding ValueColumn}"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource DdTextPrimaryBrush}"/>
          <TextBlock Text="by"
                     FontSize="13"
                     Foreground="{StaticResource DdTextMutedBrush}"/>
          <TextBlock Text="{Binding CategoryColumn}"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource DdTextPrimaryBrush}"/>
        </StackPanel>
        <TextBlock Text="auto-detected from query result"
                   FontSize="10"
                   Foreground="{StaticResource DdTextMutedBrush}"
                   Opacity="0.7"/>
      </StackPanel>

      <Grid Grid.Row="1" ColumnDefinitions="*,200">
        <Canvas Name="PieCanvas"
                Grid.Column="0"
                Background="Transparent"
                ClipToBounds="True"/>

        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled" Margin="12,0,0,0">
          <ItemsControl ItemsSource="{Binding PieSlices}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="m:PieSlice">
                <Grid ColumnDefinitions="14,*,Auto" Height="22" Margin="0,2">
                  <Border Grid.Column="0"
                          Width="12" Height="12"
                          CornerRadius="2"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Left"
                          Background="{Binding ColorHex}"/>
                  <TextBlock Grid.Column="1"
                             Text="{Binding Label}"
                             VerticalAlignment="Center"
                             Margin="6,0,6,0"
                             Foreground="{StaticResource DdTextPrimaryBrush}"
                             FontSize="12"
                             TextTrimming="CharacterEllipsis"/>
                  <TextBlock Grid.Column="2"
                             Text="{Binding Percent, StringFormat={}{0:0.#}%}"
                             VerticalAlignment="Center"
                             Foreground="{StaticResource DdTextMutedBrush}"
                             FontFamily="Consolas, Menlo, monospace"
                             FontSize="11"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
