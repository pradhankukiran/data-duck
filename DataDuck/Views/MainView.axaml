<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DataDuck.ViewModels"
             xmlns:m="using:DataDuck.Models"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
             x:Class="DataDuck.Views.MainView"
             x:DataType="vm:MainViewModel"
             Background="{StaticResource DdBgBaseBrush}"
             DragDrop.AllowDrop="True">

  <Design.DataContext>
    <vm:MainViewModel/>
  </Design.DataContext>

  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+Enter" Command="{Binding Editor.RunCommand}"/>
  </UserControl.KeyBindings>

  <Grid RowDefinitions="56,*">

    <!-- ================================================================== SETTINGS OVERLAY -->
    <Grid Grid.RowSpan="2"
          ZIndex="100"
          IsVisible="{Binding Settings.IsOpen}"
          Background="#CC000000">
      <Border Width="480"
              VerticalAlignment="Center" HorizontalAlignment="Center"
              Background="{StaticResource DdBgPanelBrush}"
              BorderBrush="{StaticResource DdBorderBrush}"
              BorderThickness="1"
              CornerRadius="10"
              Padding="24">
        <StackPanel Spacing="16">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Settings"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource DdTextPrimaryBrush}"/>
            <Button Grid.Column="1"
                    Content="✕"
                    Padding="8,2"
                    Background="Transparent"
                    Foreground="{StaticResource DdTextMutedBrush}"
                    Command="{Binding Settings.CloseCommand}"/>
          </Grid>

          <StackPanel Spacing="6">
            <TextBlock Text="Groq API key"
                       FontSize="12" FontWeight="Bold"
                       Foreground="{StaticResource DdTextMutedBrush}"
                       LetterSpacing="1"/>
            <TextBox Text="{Binding Settings.GroqApiKey, Mode=TwoWay}"
                     PlaceholderText="gsk_..."
                     PasswordChar="•"
                     FontFamily="Consolas, Menlo, monospace"/>
            <TextBlock Text="Stored only in this browser (localStorage). Not uploaded anywhere. Get a free key at console.groq.com."
                       FontSize="11"
                       Foreground="{StaticResource DdTextMutedBrush}"
                       Opacity="0.7"
                       TextWrapping="Wrap"/>
          </StackPanel>

          <TextBlock Text="{Binding Settings.StatusMessage}"
                     FontSize="11"
                     Foreground="{StaticResource DdSuccessBrush}"
                     IsVisible="{Binding Settings.StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

          <Grid ColumnDefinitions="Auto,*,Auto,Auto">
            <Button Grid.Column="0"
                    Content="Clear"
                    Padding="14,6"
                    Background="Transparent"
                    Foreground="{StaticResource DdErrorBrush}"
                    BorderBrush="{StaticResource DdBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Command="{Binding Settings.ClearCommand}"/>

            <Button Grid.Column="2"
                    Content="Cancel"
                    Padding="14,6"
                    Margin="0,0,8,0"
                    Background="Transparent"
                    Foreground="{StaticResource DdTextMutedBrush}"
                    BorderBrush="{StaticResource DdBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Command="{Binding Settings.CloseCommand}"/>

            <Button Grid.Column="3"
                    Content="Save"
                    Padding="18,6"
                    Background="{StaticResource DdAccentBrush}"
                    Foreground="#0F1419"
                    CornerRadius="4"
                    FontWeight="Medium"
                    Command="{Binding Settings.SaveCommand}"/>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <!-- ======================================================== TOP TOOLBAR -->
    <Border Grid.Row="0"
            Background="{StaticResource DdBgPanelBrush}"
            BorderBrush="{StaticResource DdBorderBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="20,0">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <TextBlock Text="🦆" FontSize="24"/>
          <TextBlock Text="DataDuck" FontSize="18" FontWeight="SemiBold"
                     Foreground="{StaticResource DdTextPrimaryBrush}"
                     VerticalAlignment="Center"/>
          <Border Background="{StaticResource DdBgHoverBrush}"
                  CornerRadius="4" Padding="6,2"
                  Margin="6,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="v0.1" FontSize="10"
                       Foreground="{StaticResource DdTextMutedBrush}"/>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Button Content="🎲  Try sample data"
                  Padding="14,6"
                  Background="{StaticResource DdAccentBrush}"
                  Foreground="#0F1419"
                  CornerRadius="6"
                  FontWeight="Medium"
                  Command="{Binding LoadSampleCommand}"/>
          <Button Content="📂  Open file"
                  Padding="14,6"
                  Background="Transparent"
                  Foreground="{StaticResource DdTextPrimaryBrush}"
                  BorderBrush="{StaticResource DdBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Command="{Binding OpenFileCommand}"/>
          <Button Content="⚙"
                  Padding="10,6"
                  Background="Transparent"
                  Foreground="{StaticResource DdTextMutedBrush}"
                  FontSize="16"
                  CornerRadius="6"
                  Command="{Binding Settings.OpenCommand}"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ======================================================== MAIN LAYOUT -->
    <Grid Grid.Row="1" ColumnDefinitions="320,*">

      <!-- ============================================== LEFT SIDEBAR -->
      <Border Grid.Column="0"
              Background="{StaticResource DdBgSidebarBrush}"
              BorderBrush="{StaticResource DdBorderBrush}"
              BorderThickness="0,0,1,0">

        <Grid RowDefinitions="Auto,*,Auto,*">

          <!-- FILES section header -->
          <StackPanel Grid.Row="0" Margin="16,16,16,8" Spacing="2">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="FILES" FontSize="11" FontWeight="Bold" LetterSpacing="1"
                         Foreground="{StaticResource DdTextMutedBrush}"/>
              <TextBlock Grid.Column="1"
                         Text="{Binding Files.Files.Count, StringFormat='{}{0}'}"
                         FontSize="11"
                         Foreground="{StaticResource DdTextMutedBrush}"
                         Opacity="0.7"/>
            </Grid>
            <TextBlock Text="Drop a CSV / Parquet / JSONL"
                       FontSize="11"
                       Foreground="{StaticResource DdTextMutedBrush}"
                       Opacity="0.6"/>
          </StackPanel>

          <!-- FILES list -->
          <ListBox Grid.Row="1"
                   Background="Transparent"
                   BorderThickness="0"
                   Padding="8,0"
                   ItemsSource="{Binding Files.Files}">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Margin" Value="0,1"/>
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate DataType="m:LoadedFile">
                <StackPanel Spacing="2">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="📄" FontSize="12" Opacity="0.7"/>
                    <TextBlock Text="{Binding Name}"
                               FontWeight="Medium" FontSize="13"
                               Foreground="{StaticResource DdTextPrimaryBrush}"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="6" Margin="18,0,0,0">
                    <TextBlock Text="{Binding RowCount, StringFormat='{}{0:N0} rows'}"
                               FontSize="11"
                               Foreground="{StaticResource DdTextMutedBrush}"/>
                    <TextBlock Text="·" Foreground="{StaticResource DdTextMutedBrush}"/>
                    <TextBlock Text="{Binding TableName}"
                               FontFamily="Consolas, Menlo, monospace"
                               FontSize="11"
                               Foreground="{StaticResource DdAccentBrush}"
                               Opacity="0.85"/>
                  </StackPanel>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- HISTORY section header -->
          <StackPanel Grid.Row="2" Margin="16,16,16,8" Spacing="2">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="QUERY HISTORY" FontSize="11" FontWeight="Bold" LetterSpacing="1"
                         Foreground="{StaticResource DdTextMutedBrush}"/>
              <TextBlock Grid.Column="1"
                         Text="{Binding History.Items.Count, StringFormat='{}{0}'}"
                         FontSize="11"
                         Foreground="{StaticResource DdTextMutedBrush}"
                         Opacity="0.7"/>
            </Grid>
          </StackPanel>

          <!-- HISTORY list -->
          <ListBox Grid.Row="3"
                   Background="Transparent"
                   BorderThickness="0"
                   Padding="8,0"
                   ItemsSource="{Binding History.Items}"
                   SelectionChanged="OnHistorySelectionChanged">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Margin" Value="0,1"/>
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate DataType="m:SavedQuery">
                <StackPanel Spacing="2">
                  <TextBlock Text="{Binding Sql}"
                             TextTrimming="CharacterEllipsis"
                             FontFamily="Consolas, Menlo, monospace"
                             FontSize="12"
                             Foreground="{StaticResource DdTextPrimaryBrush}"/>
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding ElapsedMs, StringFormat='{}{0} ms'}"
                               FontSize="10"
                               Foreground="{StaticResource DdSuccessBrush}"/>
                    <TextBlock Text="·" FontSize="10"
                               Foreground="{StaticResource DdTextMutedBrush}"/>
                    <TextBlock Text="{Binding When, StringFormat='{}{0:HH:mm:ss}'}"
                               FontSize="10"
                               Foreground="{StaticResource DdTextMutedBrush}"/>
                  </StackPanel>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- ============================================== CENTER CONTENT -->
      <Grid Grid.Column="1" RowDefinitions="*,5,*">

        <!-- ===================================== SQL EDITOR PANE -->
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto,*,Auto" Margin="20,16,20,8">

          <!-- Ask in English bar -->
          <Border Grid.Row="0"
                  Background="{StaticResource DdBgPanelBrush}"
                  CornerRadius="8"
                  BorderBrush="{StaticResource DdBorderBrush}"
                  BorderThickness="1"
                  Padding="14,4">
            <Grid ColumnDefinitions="Auto,*,Auto">
              <TextBlock Text="✨" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"
                         Foreground="{StaticResource DdAccentBrush}"/>
              <TextBox Grid.Column="1"
                       Text="{Binding Editor.EnglishQuestion, Mode=TwoWay}"
                       PlaceholderText="Ask in English (e.g. 'top 10 customers by revenue')"
                       Background="Transparent"
                       BorderThickness="0"
                       FontSize="13"
                       Foreground="{StaticResource DdTextPrimaryBrush}"/>
              <Button Grid.Column="2"
                      Content="Generate SQL"
                      Padding="12,6"
                      CornerRadius="4"
                      Background="{StaticResource DdAccentBrush}"
                      Foreground="#0F1419"
                      FontWeight="Medium"
                      FontSize="12"
                      Command="{Binding Editor.GenerateSqlCommand}"/>
            </Grid>
          </Border>

          <!-- SQL section label -->
          <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="2,16,0,6">
            <TextBlock Text="SQL"
                       FontSize="11" FontWeight="Bold" LetterSpacing="1"
                       Foreground="{StaticResource DdTextMutedBrush}"/>
            <TextBlock Text="Ctrl+Enter to run"
                       FontSize="11"
                       Foreground="{StaticResource DdTextMutedBrush}"
                       Opacity="0.6"/>
          </StackPanel>

          <!-- SQL editor -->
          <Border Grid.Row="2"
                  Background="{StaticResource DdBgPanelBrush}"
                  CornerRadius="8"
                  BorderBrush="{StaticResource DdBorderBrush}"
                  BorderThickness="1">
            <TextBox Text="{Binding Editor.SqlText, Mode=TwoWay}"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     FontFamily="Consolas, Menlo, monospace"
                     FontSize="14"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{StaticResource DdTextPrimaryBrush}"
                     Padding="14,10"
                     TextWrapping="NoWrap"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
          </Border>

          <!-- Run button + status row -->
          <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" Margin="0,12,0,0">
            <Button Grid.Column="0"
                    Content="▶  Run"
                    Padding="20,8"
                    Background="{StaticResource DdAccentBrush}"
                    Foreground="#0F1419"
                    CornerRadius="6"
                    FontWeight="SemiBold"
                    FontSize="13"
                    Command="{Binding Editor.RunCommand}"/>

            <TextBlock Grid.Column="1"
                       Text="{Binding Editor.ErrorMessage}"
                       Foreground="{StaticResource DdErrorBrush}"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Margin="16,0"
                       TextTrimming="CharacterEllipsis"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
              <TextBlock Text="{Binding Results.RowCount, StringFormat='{}{0:N0} rows'}"
                         FontSize="11"
                         Foreground="{StaticResource DdTextMutedBrush}"/>
              <TextBlock Text="·" Foreground="{StaticResource DdTextMutedBrush}"/>
              <TextBlock Text="{Binding Results.ElapsedMs, StringFormat='{}{0} ms'}"
                         FontSize="11"
                         Foreground="{StaticResource DdSuccessBrush}"/>
            </StackPanel>
          </Grid>
        </Grid>

        <!-- Splitter between editor and results -->
        <GridSplitter Grid.Row="1"
                      Background="Transparent"
                      ResizeDirection="Rows"
                      HorizontalAlignment="Stretch"
                      Height="5"/>

        <!-- ===================================== RESULTS PANE -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*" Margin="20,8,20,16">
          <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,8">
            <TextBlock Text="RESULTS" FontSize="11" FontWeight="Bold" LetterSpacing="1"
                       Foreground="{StaticResource DdTextMutedBrush}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="2"
                    Content="📋 Copy as CSV"
                    Padding="10,4"
                    Background="Transparent"
                    Foreground="{StaticResource DdTextMutedBrush}"
                    BorderBrush="{StaticResource DdBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    FontSize="11"
                    IsVisible="{Binding Results.HasRows}"/>
          </Grid>

          <Border Grid.Row="1"
                  Background="{StaticResource DdBgPanelBrush}"
                  CornerRadius="8"
                  BorderBrush="{StaticResource DdBorderBrush}"
                  BorderThickness="1">
            <Grid>
              <!-- Empty state -->
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                          Spacing="12"
                          IsVisible="{Binding !Results.HasRows}">
                <TextBlock Text="🦆" FontSize="48" HorizontalAlignment="Center" Opacity="0.4"/>
                <TextBlock Text="Run a query to see results"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource DdTextMutedBrush}"
                           FontSize="14"/>
                <TextBlock Text="Tip: drop a file in the sidebar first"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource DdTextMutedBrush}"
                           FontSize="12"
                           Opacity="0.6"/>
              </StackPanel>

              <!-- Results DataGrid — columns are rebuilt by code-behind on each query
                   (rows are object?[] indexed by column position; bind via "[N]"). -->
              <DataGrid x:Name="ResultsGrid"
                        IsVisible="{Binding Results.HasRows}"
                        ItemsSource="{Binding Results.Rows}"
                        Background="Transparent"
                        Foreground="{StaticResource DdTextPrimaryBrush}"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="False"
                        IsReadOnly="True"
                        AutoGenerateColumns="False"/>
            </Grid>
          </Border>
        </Grid>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
