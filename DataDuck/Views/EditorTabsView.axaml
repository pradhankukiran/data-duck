<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DataDuck.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="400"
             x:Class="DataDuck.Views.EditorTabsView"
             x:DataType="vm:SqlEditorTabsViewModel">

  <Design.DataContext>
    <vm:SqlEditorTabsViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

    <!-- ====================================== TAB STRIP -->
    <Border Grid.Row="0"
            BorderBrush="{StaticResource DdBorderBrush}"
            BorderThickness="0,0,0,1"
            Margin="0,0,0,8">
      <Grid ColumnDefinitions="*,Auto">
        <ListBox Grid.Column="0"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="0"
                 ItemsSource="{Binding Tabs}"
                 SelectedItem="{Binding Active, Mode=TwoWay}"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" Spacing="2"/>
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0"/>
              <Setter Property="Margin" Value="0"/>
              <Setter Property="Background" Value="{StaticResource DdBgPanelBrush}"/>
              <Setter Property="BorderBrush" Value="{StaticResource DdBorderBrush}"/>
              <Setter Property="BorderThickness" Value="1,1,1,0"/>
              <Setter Property="CornerRadius" Value="6,6,0,0"/>
              <Setter Property="MinWidth" Value="120"/>
            </Style>
            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
              <Setter Property="Background" Value="{StaticResource DdBgHoverBrush}"/>
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:EditorTab">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding Title}"
                           FontSize="12"
                           Foreground="{StaticResource DdTextPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Padding="12,6,6,6"/>
                <Button Grid.Column="1"
                        Content="✕"
                        FontSize="10"
                        Padding="6,2"
                        Margin="0,0,4,0"
                        Background="Transparent"
                        Foreground="{StaticResource DdTextMutedBrush}"
                        BorderThickness="0"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Close tab"
                        Command="{Binding ((vm:SqlEditorTabsViewModel)DataContext).CloseTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"/>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <Button Grid.Column="1"
                Content="+  New"
                Padding="10,4"
                Margin="6,0,0,0"
                FontSize="12"
                Background="Transparent"
                Foreground="{StaticResource DdTextPrimaryBrush}"
                BorderBrush="{StaticResource DdBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                ToolTip.Tip="Open a new SQL tab"
                Command="{Binding AddTabCommand}"/>
      </Grid>
    </Border>

    <!-- ====================================== ENGLISH-QUESTION BAR -->
    <Border Grid.Row="1"
            Background="{StaticResource DdBgPanelBrush}"
            CornerRadius="8"
            BorderBrush="{StaticResource DdBorderBrush}"
            BorderThickness="1"
            Padding="14,4"
            IsVisible="{Binding Active, Converter={x:Static ObjectConverters.IsNotNull}}">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <TextBlock Text="✨" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"
                   Foreground="{StaticResource DdAccentBrush}"/>
        <TextBox Grid.Column="1"
                 Text="{Binding Active.Editor.EnglishQuestion, Mode=TwoWay}"
                 PlaceholderText="Ask in English (e.g. 'top 10 customers by revenue')"
                 Background="Transparent"
                 BorderThickness="0"
                 FontSize="13"
                 Foreground="{StaticResource DdTextPrimaryBrush}"/>
        <Button Grid.Column="2"
                Content="Generate SQL"
                Padding="12,6"
                CornerRadius="4"
                Background="{StaticResource DdAccentBrush}"
                Foreground="#0F1419"
                FontWeight="Medium"
                FontSize="12"
                Command="{Binding Active.Editor.GenerateSqlCommand}"/>
      </Grid>
    </Border>

    <!-- ====================================== SQL LABEL ROW -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="2,16,0,6">
      <TextBlock Text="SQL"
                 FontSize="11" FontWeight="Bold" LetterSpacing="1"
                 Foreground="{StaticResource DdTextMutedBrush}"/>
      <TextBlock Text="Ctrl+Enter to run"
                 FontSize="11"
                 Foreground="{StaticResource DdTextMutedBrush}"
                 Opacity="0.6"/>
    </StackPanel>

    <!-- ====================================== SQL TEXT BOX -->
    <Border Grid.Row="3"
            Background="{StaticResource DdBgPanelBrush}"
            CornerRadius="8"
            BorderBrush="{StaticResource DdBorderBrush}"
            BorderThickness="1"
            IsVisible="{Binding Active, Converter={x:Static ObjectConverters.IsNotNull}}">
      <TextBox Text="{Binding Active.Editor.SqlText, Mode=TwoWay}"
               AcceptsReturn="True"
               AcceptsTab="True"
               FontFamily="Consolas, Menlo, monospace"
               FontSize="14"
               Background="Transparent"
               BorderThickness="0"
               Foreground="{StaticResource DdTextPrimaryBrush}"
               Padding="14,10"
               TextWrapping="NoWrap"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"
               ScrollViewer.VerticalScrollBarVisibility="Auto"/>
    </Border>

    <!-- ====================================== RUN BAR -->
    <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto" Margin="0,12,0,0"
          IsVisible="{Binding Active, Converter={x:Static ObjectConverters.IsNotNull}}">
      <Button Grid.Column="0"
              Content="▶  Run"
              Padding="20,8"
              Background="{StaticResource DdAccentBrush}"
              Foreground="#0F1419"
              CornerRadius="6"
              FontWeight="SemiBold"
              FontSize="13"
              Command="{Binding Active.Editor.RunCommand}"/>

      <TextBlock Grid.Column="1"
                 Text="{Binding Active.Editor.ErrorMessage}"
                 Foreground="{StaticResource DdErrorBrush}"
                 VerticalAlignment="Center"
                 FontSize="12"
                 Margin="16,0"
                 TextTrimming="CharacterEllipsis"/>
    </Grid>
  </Grid>
</UserControl>
